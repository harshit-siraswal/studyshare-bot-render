# Core
NODE_ENV=production
PORT=8080
LOG_LEVEL=info
INGEST_BODY_LIMIT_MB=30

# Postgres (Supabase connection pooler for IPv4 compatibility)
# Transaction pooler (port 6543) — disable prepared statements in db.ts
DATABASE_URL=postgresql://postgres.iayuwsvguwfqjgjsvjiy:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Session pooler (port 5432) — alternative if transaction pooler has issues
# DATABASE_URL=postgresql://postgres.iayuwsvguwfqjgjsvjiy:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# StudyShare backend
STUDYSHARE_API_BASE=https://api.studyshare.in
STUDYSHARE_ADMIN_BEARER=your-admin-key-hash-or-bearer
STUDYSHARE_POST_MODE=browser
STUDYSHARE_ADMIN_APP_BASE=https://admin-studyspace-official.vercel.app
STUDYSHARE_ADMIN_DEFAULT_COLLEGE_ID=your-college-uuid

# Browser posting
STUDYSHARE_BROWSER_EXECUTABLE_PATH=/usr/bin/chromium
STUDYSHARE_BROWSER_HEADLESS=true
STUDYSHARE_BROWSER_TIMEOUT_MS=90000

# API paths (defaults are fine)
STUDYSHARE_UPLOADS_PRESIGN_PATH=/api/admin/uploads/presign
STUDYSHARE_RESOURCES_PATH=/api/admin/resources
STUDYSHARE_NOTICES_PATH=/api/admin/notices
STUDYSHARE_SYLLABUS_PATH=/api/admin/syllabus
STUDYSHARE_LEGACY_ADMIN_PATH=/api/admin

# Classification
AUTO_POST_CONFIDENCE_THRESHOLD=0.78
ENABLE_LLM_CLASSIFIER=true
ENABLE_CHAT_AGENT=true
ENABLE_GEMINI_VISION_OCR=true
ENABLE_GOOGLE_VISION_OCR=true
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash
CHAT_AGENT_MODEL=gemini-1.5-flash
GEMINI_VISION_OCR_MAX_PAGES=3
GOOGLE_VISION_OCR_MAX_PAGES=3

# Optional alerting
OPS_ALERT_WEBHOOK_URL=
MOLTBOT_CHAT_WEBHOOK_URL=
MOLTBOT_REVIEW_NOTIFY_WEBHOOK_URL=

# OCR helper
PYTHON_BIN=python3
